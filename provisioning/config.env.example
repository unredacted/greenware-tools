# =============================================================================
# GreenWare Provisioning Configuration
# =============================================================================
# Copy this file to config.env and fill in your values:
#   cp config.env.example config.env
#
# IMPORTANT: Never commit config.env to git — it contains secrets.
# =============================================================================

# --- Tailscale / Headscale ---------------------------------------------------

# Reusable pre-auth key from your Headscale instance.
# Generate with: headscale preauthkeys create --user <USER> --reusable --expiration 90d
# Revoke after provisioning: headscale preauthkeys expire --id <KEY_ID>
TAILSCALE_AUTH_KEY="tskey-preauth-REPLACE_ME"

# Headscale login server URL (no trailing slash)
HEADSCALE_URL="https://my.headscale.net"

# --- Hostnames ---------------------------------------------------------------

# Hostnames follow the pattern: ${HOSTNAME_PREFIX}${NUMBER}${HOSTNAME_SUFFIX}
# Example: pi-exit-relay26-tor-ce
HOSTNAME_PREFIX="pi-exit-relay"
HOSTNAME_SUFFIX="-tor-ce"

# Starting number for sequential hostnames (inclusive)
HOSTNAME_START=26

# Ending number for sequential hostnames (inclusive, used by batch-flash only)
HOSTNAME_END=125

# --- SSH Access --------------------------------------------------------------

# Your SSH public key (ed25519 recommended). This will be the only way to
# access the Pis, since password auth is disabled.
SSH_PUBLIC_KEY="ssh-ed25519 AAAA... your-public-key-here"

# --- Admin User --------------------------------------------------------------

# Username for the admin account created on each Pi
ADMIN_USER="admin"

# Password for local console login (keyboard+monitor).
# SSH still uses key-only auth. Set to empty string to disable password login.
ADMIN_PASSWORD="changeme"

# --- OS Image ----------------------------------------------------------------

# Filename of the Raspberry Pi OS Lite image.
# Download from: https://downloads.raspberrypi.com/raspios_lite_arm64/images/
# Use the .img.xz file directly — no need to decompress!
# (Decompressed .img files are also supported but will be recompressed.)
OS_IMAGE="2025-12-04-raspios-trixie-arm64-lite.img.xz"

# --- macOS Batch Flash (batch-flash.sh only) ---------------------------------

# Disk identifier for the SD card reader on macOS.
# Find with: diskutil list
# DOUBLE-CHECK THIS — wrong value will erase the wrong drive!
SD_DISK="/dev/disk4"

# --- USB Provisioner (prepare-usb.sh only) -----------------------------------

# Disk identifier for the USB-A stick on macOS.
# Find with: diskutil list
# DOUBLE-CHECK THIS — wrong value will erase the wrong drive!
USB_DISK="/dev/disk5"
